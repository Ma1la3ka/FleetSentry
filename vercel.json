{
  "name": "tracksafe",
  "buildCommand": "npm run build",
  "devCommand": "npm start",
  "outputDirectory": "./",
  "framework": "static",
  "env": [],
  "functions": {},
  "routes": [
    {
      "src": "/(.*)",
      "dest": "$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ]
}
